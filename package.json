    "octokit": "^5.0.5",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "yaml": "^2.8.3"
