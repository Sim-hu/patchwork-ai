{
  "name": "patchwork-ai",
  "version": "0.1.0",
  "description": "AI-powered CLI that automates OSS contributions",
  "type": "module",
  "bin": {
    "patchwork-ai": "./dist/bin/patchwork-ai.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
